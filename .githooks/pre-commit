#!/bin/sh
# Pre-commit hook: run golangci-lint on staged Go files

# Check if golangci-lint is installed
if ! command -v golangci-lint >/dev/null 2>&1; then
  echo "golangci-lint not found. Install: https://golangci-lint.run/welcome/install/"
  echo "Skipping lint."
  exit 0
fi

# Only run if there are staged .go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$')
if [ -z "$STAGED_GO_FILES" ]; then
  exit 0
fi

echo "Running golangci-lint..."
golangci-lint run ./...
if [ $? -ne 0 ]; then
  echo ""
  echo "Lint failed. Fix the issues above or commit with --no-verify to skip."
  exit 1
fi
